# Config syntax crash course
# ==========================
# # The config file consists of simple key-value pairs,
# # separated by equals signs.
font-family = SauceCodePro NF
clipboard-read = allow
clipboard-write = allow
font-size = 13
theme = Catppuccin Mocha
background-opacity = 0.95
background-blur = true
window-decoration = none
window-height = 85
window-width = 159

# Split vertical (tmux)
keybind = super+shift+d=text:\x01\x5f

# Split horizontal (tmux)
keybind = super+d=text:\x01\x7c

# New tab (tmux)
keybind = super+t=text:\x01\x63

# Close pane
keybind = super+w=text:\x01\x78

# Move between panes
keybind = super+alt+arrow_up=text:\x01\x1b\x5b\x41
keybind = super+alt+arrow_down=text:\x01\x1b\x5b\x42
keybind = super+alt+arrow_left=text:\x01\x1b\x5b\x44
keybind = super+alt+arrow_right=text:\x01\x1b\x5b\x43

# Resize panes
keybind = super+ctrl+arrow_up=text:\x01\x1b\x5b\x31\x3b\x35\x41
keybind = super+ctrl+arrow_down=text:\x01\x1b\x5b\x31\x3b\x35\x42
keybind = super+ctrl+arrow_left=text:\x01\x1b\x5b\x31\x3b\x35\x44
keybind = super+ctrl+arrow_right=text:\x01\x1b\x5b\x31\x3b\x35\x43

# Go to full-screen
keybind = super+shift+enter=text:\x01\x2b

# Move between tabs
keybind = ctrl+tab=text:\x01\x3e
keybind = ctrl+shift+tab=text:\x01\x3c


